# Tell GitHub Linguist what to count as the primary language
# and what to ignore for language detection stats

# Treat all Ruby files as Ruby (explicit, good practice)
*.rb        linguist-language=Ruby
*.gemspec   linguist-language=Ruby
Gemfile     linguist-language=Ruby
Rakefile    linguist-language=Ruby

# Exclude ALL non-Ruby files from language detection
*.md        linguist-detectable=false
*.txt       linguist-detectable=false
*.yml       linguist-detectable=false
*.yaml      linguist-detectable=false
*.json      linguist-detectable=false
*.html      linguist-detectable=false
*.lock      linguist-detectable=false

# Exclude spec and doc directories entirely
spec/**     linguist-detectable=false
docs/**     linguist-detectable=false
